# Appwrite — copy to .env.local and fill in values from the Appwrite console.
# https://cloud.appwrite.io (or your self-hosted URL)

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://<region>.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT=<project_id>
NEXT_PUBLIC_APPWRITE_DATABASE=<database_id>
NEXT_PUBLIC_APPWRITE_USERS_COLLECTION=<users_collection_id>
NEXT_PUBLIC_APPWRITE_FILES_COLLECTION=<files_collection_id>
NEXT_PUBLIC_APPWRITE_BUCKET=<storage_bucket_id>

# API key with access your app needs (server-only; never commit real keys)
NEXT_APPWRITE_KEY=<server_api_key>
